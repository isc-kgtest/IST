@inherits LayoutComponentBase

<MudThemeProvider @ref="@_themeProvider" @bind-IsDarkMode="@_isDarkMode" Theme="MyCustomTheme" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h5" Class="ml-3">IST Admin Suite</MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.Brightness4" Color="Color.Inherit" OnClick="@ToggleDarkMode" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <MudNavMenu>
            <div class="pa-4">
                <MudText Typo="Typo.h6">Навигация</MudText>
            </div>

            @* Основные рабочие разделы *@
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Дашборд</MudNavLink>
            <MudNavLink Href="/nsi" Icon="@Icons.Material.Filled.Storage">Управление НСИ</MudNavLink>
            <MudNavLink Href="/dictionaries" Icon="@Icons.Material.Filled.MenuBook">Справочники</MudNavLink>
            <MudNavLink Href="/requests" Icon="@Icons.Material.Filled.Assignment">Управление заявками</MudNavLink>
            <MudNavLink Href="/trials" Icon="@Icons.Material.Filled.Science">Управление испытаниями</MudNavLink>
            <MudNavLink Href="/authorities" Icon="@Icons.Material.Filled.AccountBalance">Взаимодействие с органами</MudNavLink>
    
            @* Аналитика и интеграции *@
            <MudNavLink Href="/reports" Icon="@Icons.Material.Filled.PieChart">Отчеты и аналитика</MudNavLink>
            <MudNavLink Href="/exchange" Icon="@Icons.Material.Filled.SyncAlt">Обмен данными</MudNavLink>

            @* Системные настройки (визуально отделены) *@
            <MudDivider Class="my-2" />
            <div class="px-4 pb-2 pt-2">
                <MudText Typo="Typo.caption" Color="Color.Dark">СИСТЕМА</MudText>
            </div>

            <MudNavLinkAuthRole Href="/authadminpage" Icon="@Icons.Material.Filled.AdminPanelSettings" Roles="admin">
                Управление доступом
            </MudNavLinkAuthRole>
            <MudNavLink Href="/security" Icon="@Icons.Material.Filled.Security">Безопасность</MudNavLink>

            <MudNavLinkLoginState />
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-6 px-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    bool _drawerOpen = true;
    bool _isDarkMode = false;
    private MudThemeProvider _themeProvider = null!;

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    void ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
    }

    MudTheme MyCustomTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#37474F", // BlueGrey.Darken3
            AppbarBackground = "#263238", // BlueGrey.Darken4
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#78909C" // BlueGrey.Lighten1
        }
    };
}
