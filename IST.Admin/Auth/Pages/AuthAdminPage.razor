@page "/authadminpage"
@using IST.Shared.Models
@using IST.UI.Models
@using IST.Admin.Auth.Components

@attribute [Authorize(Roles = "admin")]

<PageTitle>Панель управления доступом</PageTitle>

<MudAlert Elevation="0" Dense="true" Class="my-2">
	Панель управления доступом
</MudAlert>

<MudTabs @bind-DisableRipple="_processing" Outlined="true" Rounded="true" ApplyEffectsToContainer="true">
	<MudTabPanel Text="Пользователи">
		<MudDynamicTable Title="Список" Items="@_users">
			<AddButton>
				<MudTooltip Placement="Placement.Top" Text="Создать нового пользователя">
					<MudFab Class="ml-2" Color="Color.Success" StartIcon="@Icons.Material.Rounded.GroupAdd" OnClick="ShowCreateUserForm" />
				</MudTooltip>
				<MudTooltip Placement="Placement.Top" Text="Обновить">
					<MudFab Class="ml-2" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Refresh" OnClick="GetAllUsers" />
				</MudTooltip>
			</AddButton>
		</MudDynamicTable>
	</MudTabPanel>
	<MudTabPanel Text="Роли">
		<MudDynamicTable Title="Список" Items="@_roles">
			<AddButton>
				<MudTooltip Placement="Placement.Top" Text="Добавить новый роль">
					<MudFab Class="ml-2" Color="Color.Success" StartIcon="@Icons.Material.Rounded.AddModerator" OnClick="ShowCreateRoleForm" />
				</MudTooltip>
				<MudTooltip Placement="Placement.Top" Text="Обновить">
					<MudFab Class="ml-2" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Refresh" OnClick="GetAllRoles" />
				</MudTooltip>
			</AddButton>
		</MudDynamicTable>
	</MudTabPanel>
</MudTabs>

