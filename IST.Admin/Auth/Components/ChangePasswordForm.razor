
@using ActualLab.Fusion
@using IST.Contracts.Features.Auth
@using IST.Contracts.Features.Auth.Commands
@using Microsoft.AspNetCore.Components.Forms

@inject IAuthCommands _authCommands
@inject IST.Admin.Auth.SessionAccessor _session

<MudPaper Elevation="0" Style="width: 370px;">
    <EditForm Model="@changeUserPasswordRequest" OnValidSubmit="SubmitForm">
        <DataAnnotationsValidator />
        <MudTextField T="string"
                      @bind-Value="changeUserPasswordRequest.Login"
                      For="@(() => changeUserPasswordRequest.Login)"
                      Label="Логин"
                      ReadOnly="true"
                      Required="true" />
        <MudTextField T="string"
                      @bind-Value="changeUserPasswordRequest.CurrentPassword"
                      For="@(() => changeUserPasswordRequest.CurrentPassword)"
                      Label="Текущий пароль"
                      Required="true"
                      Class="mt-3"
                      InputType="@CurrentPassword.Type"
                      Adornment="Adornment.End"
                      AdornmentIcon="@CurrentPassword.Icon"
                      OnAdornmentClick="() => ShowPassword(CurrentPassword)"
                      AdornmentAriaLabel="Show Password" />
        <MudTextField T="string"
                      @bind-Value="changeUserPasswordRequest.NewPassword"
                      For="@(() => changeUserPasswordRequest.NewPassword)"
                      Label="Новый пароль"
                      Required="true"
                      Class="mt-3"
                      InputType="@NewPassword.Type"
                      Adornment="Adornment.End"
                      AdornmentIcon="@NewPassword.Icon"
                      OnAdornmentClick="() => ShowPassword(NewPassword)"
                      AdornmentAriaLabel="Show Password" />
        <MudTextField T="string"
                      @bind-Value="changeUserPasswordRequest.ConfirmPassword"
                      For="@(() => changeUserPasswordRequest.ConfirmPassword)"
                      Label="Подтверждение пароля"
                      Required="true"
                      Class="mt-3"
                      InputType="@ConfirmPassword.Type"
                      Adornment="Adornment.End"
                      AdornmentIcon="@ConfirmPassword.Icon"
                      OnAdornmentClick="() => ShowPassword(ConfirmPassword)"
                      AdornmentAriaLabel="Show Password" />
        <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-5" Spacing="2">
            <MudButton OnClick="Cancel"
                       Variant="Variant.Text"
                       Color="Color.Default"
                       Disabled="_isProcessing">
                Отмена
            </MudButton>
            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Info"
                       Disabled="_isProcessing">
                @(_isProcessing ? "Сохранение..." : "Изменить")
            </MudButton>
        </MudStack>
        <MudProgressLinear Color="Color.Info" Indeterminate="_isProcessing" Class="mt-4" />
    </EditForm>
</MudPaper>

@code {

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public string Login { get; set; } = "";

    private bool _isProcessing;

    protected override void OnParametersSet()
    {
        changeUserPasswordRequest.Login = Login;
    }

    private class PasswordFieldState
    {
        public InputType Type { get; set; } = InputType.Password;
        public string Icon { get; set; } = Icons.Material.Filled.VisibilityOff;
    }

    private PasswordFieldState CurrentPassword { get; set; } = new();
    private PasswordFieldState NewPassword { get; set; } = new();
    private PasswordFieldState ConfirmPassword { get; set; } = new();

    void ShowPassword(PasswordFieldState field)
    {
        if (field.Type == InputType.Password)
        {
            field.Type = InputType.Text;
            field.Icon = Icons.Material.Filled.Visibility;
        }
        else
        {
            field.Type = InputType.Password;
            field.Icon = Icons.Material.Filled.VisibilityOff;
        }

        StateHasChanged();
    }

    private ChangeUserPasswordRequest changeUserPasswordRequest { get; set; } = new();

    private void Cancel() => MudDialog?.Cancel();

    private async Task SubmitForm()
    {
        if (_isProcessing)
            return;

        _isProcessing = true;

        try
        {
            var command = new ChangeUserPasswordCommand(await _session.GetAsync(), changeUserPasswordRequest);
            var res = await _authCommands.ChangeUserPasswordAsync(command);

            if (res.Status)
            {
                _snackbar.Add($"Пароль успешно изменён: {res.Data}", Severity.Success);
                MudDialog?.Close(DialogResult.Ok(true));
            }
            else
            {
                _snackbar.Add($"Ошибка при изменении пароля: {res.StatusMessage}", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            _snackbar.Add($"Непредвиденная ошибка: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }
}
