
@using ActualLab.Fusion
@using IST.Contracts.Features.Auth.Commands
@using Microsoft.AspNetCore.Components.Forms

@inject ICommander Commander
@inject ISessionResolver SessionResolver

<MudPaper Elevation="0" Style="width: 370px;">
    <EditForm Model="@changeUserPasswordRequest" OnValidSubmit="SubmitForm">
        <DataAnnotationsValidator />
        @* <MudText Typo="Typo.h5" GutterBottom="true">Изменить пароль</MudText> *@
        <MudTextField T="string"
                      @bind-Value="changeUserPasswordRequest.Login"
                      For="@(() => changeUserPasswordRequest.Login)"
                      Label="Логин"
                      ReadOnly=true
                      Required="true" />
        <MudTextField T="string"
                      @bind-Value="changeUserPasswordRequest.CurrentPassword"
                      For="@(() => changeUserPasswordRequest.CurrentPassword)"
                      Label="Текущий пароль"
                      Required="true"
                      InputType="@CurrentPassword.Type" Adornment="Adornment.End" AdornmentIcon="@CurrentPassword.Icon" OnAdornmentClick="() => ShowPassword(CurrentPassword)" AdornmentAriaLabel="Show Password" />
        <MudTextField T="string"
                      @bind-Value="changeUserPasswordRequest.NewPassword"
                      For="@(() => changeUserPasswordRequest.NewPassword)"
                      Label="Новый пароль"
                      Required="true"
                      Class="mt-3"
                      InputType="@NewPassword.Type" Adornment="Adornment.End" AdornmentIcon="@NewPassword.Icon" OnAdornmentClick="() => ShowPassword(NewPassword)" AdornmentAriaLabel="Show Password" />
        <MudTextField T="string"
                      @bind-Value="changeUserPasswordRequest.ConfirmPassword"
                      For="@(() => changeUserPasswordRequest.ConfirmPassword)"
                      Label="Подтверждение пароля"
                      Required="true"
                      Class="mt-3"
                      InputType="@ConfirmPassword.Type" Adornment="Adornment.End" AdornmentIcon="@ConfirmPassword.Icon" OnAdornmentClick="() => ShowPassword(ConfirmPassword)" AdornmentAriaLabel="Show Password" />
        <MudButton ButtonType="ButtonType.Submit"
                   Variant="Variant.Filled"
                   Color="Color.Info"
                   Class="mt-5">
            Изменить
        </MudButton>
    </EditForm>
</MudPaper>

@code {

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }
  
    [Parameter]
    public string Login { get; set; } = "";

    protected override async Task OnParametersSetAsync()
    {
        changeUserPasswordRequest.Login = Login;
    }

    private class PasswordFieldState
    {
        public InputType Type { get; set; } = InputType.Password;
        public string Icon { get; set; } = Icons.Material.Filled.VisibilityOff;
    }

    private PasswordFieldState CurrentPassword { get; set; } = new();
    private PasswordFieldState NewPassword { get; set; } = new();
    private PasswordFieldState ConfirmPassword { get; set; } = new();

    void ShowPassword(PasswordFieldState field)
    {
        if (field.Type == InputType.Password)
        {
            field.Type = InputType.Text;
            field.Icon = Icons.Material.Filled.Visibility;
        }
        else
        {
            field.Type = InputType.Password;
            field.Icon = Icons.Material.Filled.VisibilityOff;
        }

        // Нужно обновить состояние компонента, чтобы изменения отразились
        StateHasChanged();
    }

    // Экземпляр модели, к которому привязана форма.
    private ChangeUserPasswordRequest changeUserPasswordRequest { get; set; } = new();

    /// <summary>
    /// Этот метод вызывается при нажатии на кнопку "Изменить".
    /// </summary>
    private async Task SubmitForm()
    {
        var session = SessionResolver.Session;
        var cmd = new ChangeUserPasswordCommand(session, changeUserPasswordRequest);
        var res = await Commander.Call(cmd);

        if (res.Status)
        {
            var userName = res.Data;
            _snackbar.Add($"Пароль успешно изменен: {userName} !", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        else
        {
            _snackbar.Add($"Ошибка при изменении пароля! {res.StatusMessage}", Severity.Warning);
        }
    }
}