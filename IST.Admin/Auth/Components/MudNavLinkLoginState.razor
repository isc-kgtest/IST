@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing
@using System.Security.Claims

<AuthorizeView>
    <Authorized>
        <MudNavGroup Title="@context.User.Claims.Where(c => c.Type.Equals(ClaimTypes.Name)).Select(c => c.Value).FirstOrDefault()" IconColor="Color.Info" Icon="@Icons.Material.TwoTone.ManageAccounts" HideExpandIcon="IsDrawerVariantMini">
			<MudTooltip Text="Смена пароля" Arrow="true" Placement="Placement.Left" Disabled="!IsDrawerVariantMini" RootStyle="width: 100%;">
				<MudNavLinkAuthRole Icon="@Icons.Material.Filled.LockReset" OnClick="ShowChangePasswordForm">
					Смена пароля
				</MudNavLinkAuthRole>
			</MudTooltip>
			<MudTooltip Text="Выйти" Arrow="true" Placement="Placement.Left" Disabled="!IsDrawerVariantMini" RootStyle="width: 100%;">
            	<MudNavLink OnClick="Logout" Icon="@Icons.Material.TwoTone.Logout">Выйти</MudNavLink>
			</MudTooltip>
        </MudNavGroup>
    </Authorized>
    <NotAuthorized>
        <MudNavLink Href="/login" Icon="@Icons.Material.TwoTone.Login" IconColor="Color.Primary">Войти</MudNavLink>
    </NotAuthorized>
</AuthorizeView>

@inject AuthenticationStateProvider AuthStateProvider

@code {
	[Parameter] public bool IsDrawerVariantMini { get; set; }
	
	public async Task Logout()
	{
		_navManager.NavigateTo("/api/auth/logout", forceLoad: true);
	}

	private async Task ShowChangePasswordForm()
	{
		var authState = await AuthStateProvider.GetAuthenticationStateAsync();
		var user = authState.User;

		if (user.Identity?.IsAuthenticated == true)
		{
			var userName = user.Claims?.Where(c => c.Type.Equals(ClaimTypes.Name))?.FirstOrDefault()?.Value ?? "";

			IDialogReference dialogRef = default!;
			void CancelDialog() => dialogRef.Close(DialogResult.Cancel());
			void ConfirmDialog() => dialogRef.Close(DialogResult.Ok(true));

			var parameters = new DialogParameters
			{
				["ChildContent"] = (RenderFragment)(builder =>
				{
					builder.OpenComponent<ChangePasswordForm>(0); // Правильный способ добавить компонент
					builder.AddAttribute(1, "Login", userName);
					builder.CloseComponent();
				}),
			};

			var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium };

			await _dialogService.ShowAsync<MudDynamicDialog>("Изменить пароль", parameters, options);
		}		
	}
}