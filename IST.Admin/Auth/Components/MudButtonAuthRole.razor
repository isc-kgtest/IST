@using Microsoft.AspNetCore.Components.Authorization

<AuthorizeView Roles="@Roles">
    <Authorized>
        <MudButton StartIcon="@StartIcon"
                   EndIcon="@EndIcon"
                   Class="@Class"
                   IconSize="@IconSize"
                   Variant="@Variant"
                   Disabled="@Disabled"
                   OnClick="@OnClick"
                   Style="@Style">
            @ChildContent
        </MudButton>
    </Authorized>
    <NotAuthorized>
        @if (Visibled)
        {
            <MudButton StartIcon="@StartIcon"
                       EndIcon="@EndIcon"
                       Class="@Class"
                       IconSize="@IconSize"
                       Variant="@Variant"
                       Disabled="true"
                       OnClick="@OnClick"
                       Style="@Style">
                @ChildContent
            </MudButton>
        }
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public Variant Variant { get; set; } = Variant.Text;
    [Parameter] public bool Visibled { get; set; } = false;
    [Parameter] public string? StartIcon { get; set; }
    [Parameter] public string? EndIcon { get; set; }
    [Parameter] public Size? IconSize { get; set; }
    [Parameter] public string? Roles { get; set; } = null;
    [Parameter] public string? Style { get; set; } = null;
    [Parameter] public string? Class { get; set; } = null;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback<MouseEventArgs> OnClick { get; set; }
}
