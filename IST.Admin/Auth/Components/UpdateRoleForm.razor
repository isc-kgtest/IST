
@using Microsoft.AspNetCore.Components.Forms

<MudPaper Class="" Elevation="0">
    <EditForm Model="@updateRoleModel" OnValidSubmit="SubmitForm">
        <DataAnnotationsValidator />
        <MudTextField T="string"
                      @bind-Value="updateRoleModel.Name"
                      For="@(() => updateRoleModel.Name)"
                      Label="Название"
                      Required="true" />
        <MudTextField T="string"
                      @bind-Value="updateRoleModel.Description"
                      For="@(() => updateRoleModel.Description)"
                      Label="Описание"
                      Required="true"
                      Class="mt-3" />
        <MudCheckBox @bind-Value="updateRoleModel.Disabled"
                     Label="Заблокировать роль"
                     Color="Color.Primary"
                     Class="mt-3" />
        <MudButton ButtonType="ButtonType.Submit"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   Class="mt-5">
            Сохранить
        </MudButton>
    </EditForm>
</MudPaper> 

@code {

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [CascadingParameter(Name = "UserProfile")]
    private UserProfile UserProfile { get; set; }

    [Parameter]
    public Ulid RoleId { get; set; }

    // Экземпляр модели, к которому привязана форма.
    private UpdateRoleCommand updateRoleModel = new() { UserProfile = new UserProfile() };

    protected override async Task OnParametersSetAsync()
    {
        var res = await _mediatr.Send(new GetRoleQuery { Id = RoleId, UserProfile = UserProfile });

        // Проверяем статус ответа от сервера
        if (res.Status) // Если Status === true, значит, пользователь успешно найден
        {            
            var role = res.Data;

            updateRoleModel.Id = role.Id;
            updateRoleModel.Name = role.Name;
            updateRoleModel.Description = role.Description;
            updateRoleModel.Disabled = role.Disabled;

            _snackbar.Add($"Роль '{updateRoleModel.Name}' успешно загружен!", Severity.Success);

            StateHasChanged();
        }
        else // Если Status === false, значит, произошла ошибка при получении
        {
            _snackbar.Add($"Не удалось загрузить роль: {res.StatusMessage}", Severity.Error);
        }
    }    

    /// <summary>
    /// Этот метод вызывается при нажатии на кнопку "Сохранить".
    /// </summary>
    private async Task SubmitForm()
    {
        updateRoleModel.UserProfile =  UserProfile;
        var res = await _mediatr.Send(updateRoleModel);

        if (res.Status)
        {
            var user = res.Data;
            _snackbar.Add($"Роль успешно сохранен: {user.Name} !", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        else
        {
            _snackbar.Add($"Ошибка сохранения! {res.StatusMessage}", Severity.Warning);
        }
    }
}