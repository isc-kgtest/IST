
@using ActualLab.Fusion
@using IST.Contracts.Features.Auth
@using IST.Contracts.Features.Auth.Commands
@using Microsoft.AspNetCore.Components.Forms

@inject IAuthCommands _authCommands
@inject IAuthQueries _authQueries
@inject IST.Admin.Auth.SessionAccessor _session

<MudPaper Elevation="0" Style="min-width: 360px;">
    @if (_loading)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-8">
            <MudProgressCircular Indeterminate="true" />
            <MudText Typo="Typo.caption">Загрузка данных...</MudText>
        </MudStack>
    }
    else if (_notFound)
    {
        <MudAlert Severity="Severity.Error">Роль не найдена.</MudAlert>
    }
    else
    {
        <EditForm Model="@_request" OnValidSubmit="SubmitForm">
            <DataAnnotationsValidator />
            <MudTextField T="string"
                          @bind-Value="_request.Name"
                          For="@(() => _request.Name)"
                          Label="Название"
                          Required="true" />
            <MudTextField T="string"
                          @bind-Value="_request.Description"
                          For="@(() => _request.Description)"
                          Label="Описание"
                          Required="true"
                          Class="mt-3" />
            <MudCheckBox @bind-Value="_request.Disabled"
                         Label="Заблокировать роль"
                         Color="Color.Primary"
                         Class="mt-3" />
            <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-5" Spacing="2">
                <MudButton OnClick="Cancel"
                           Variant="Variant.Text"
                           Color="Color.Default"
                           Disabled="_isProcessing">
                    Отмена
                </MudButton>
                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Disabled="_isProcessing">
                    @(_isProcessing ? "Сохранение..." : "Сохранить")
                </MudButton>
            </MudStack>
            <MudProgressLinear Color="Color.Primary" Indeterminate="_isProcessing" Class="mt-4" />
        </EditForm>
    }
</MudPaper>

@code {

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public Guid RoleId { get; set; }

    private bool _loading = true;
    private bool _notFound;
    private bool _isProcessing;

    private UpdateRoleRequest _request { get; set; } = new();

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _notFound = false;

        try
        {
            var role = await _authQueries.GetRoleByIdAsync(RoleId);

            if (role == null)
            {
                _notFound = true;
                _snackbar.Add("Не удалось загрузить роль", Severity.Error);
                return;
            }

            _request = new UpdateRoleRequest
            {
                Id = role.Id,
                Name = role.Name ?? "",
                Description = role.Description ?? "",
                Disabled = role.IsDeleted
            };
        }
        catch (Exception ex)
        {
            _snackbar.Add($"Ошибка загрузки: {ex.Message}", Severity.Error);
            _notFound = true;
        }
        finally
        {
            _loading = false;
        }
    }

    private void Cancel() => MudDialog?.Cancel();

    private async Task SubmitForm()
    {
        if (_isProcessing)
            return;

        _isProcessing = true;

        try
        {
            var command = new UpdateRoleCommand(await _session.GetAsync(), _request);
            var res = await _authCommands.UpdateRoleAsync(command);

            if (res.Status && res.Data != null)
            {
                _snackbar.Add($"Роль успешно сохранена: {res.Data.Name}", Severity.Success);
                MudDialog?.Close(DialogResult.Ok(true));
            }
            else
            {
                _snackbar.Add($"Ошибка сохранения: {res.StatusMessage}", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            _snackbar.Add($"Непредвиденная ошибка: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }
}
