@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing

<AuthorizeView Roles="@Roles">
    <Authorized>
        <MudNavLink Disabled="@Disabled" Href="@Href" Icon="@Icon" Match="@Match" OnClick="@OnClick">
            @ChildContent
        </MudNavLink>
    </Authorized>
    <NotAuthorized>
        @if (Visibled)
        {
            <MudNavLink Href="@Href" Icon="@Icon" Match="@Match" Disabled="true">
                @ChildContent
            </MudNavLink>
        }        
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Visibled { get; set; }
    [Parameter] public string? Href { get; set; }
    [Parameter] public string? Icon { get; set; }
    [Parameter] public NavLinkMatch Match { get; set; } = NavLinkMatch.Prefix;
    [Parameter] public string? Roles { get; set; } = null;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback<MouseEventArgs> OnClick { get; set; }
}
