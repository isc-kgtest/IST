
@using Microsoft.AspNetCore.Components.Forms

<MudPaper Class="" Elevation="0">
    <EditForm Model="@resetUserPasswordRequest" OnValidSubmit="SubmitForm">
        <DataAnnotationsValidator />
        @* <MudText Typo="Typo.h5" GutterBottom="true">Изменить пароль</MudText> *@
        <MudTextField T="string"
                      @bind-Value="resetUserPasswordRequest.UserName"
                      For="@(() => resetUserPasswordRequest.UserName)"
                      Label="Логин"
                      ReadOnly="true"
                      Required="true" />        
        <MudTextField T="string"
                      @bind-Value="resetUserPasswordRequest.NewPassword"
                      For="@(() => resetUserPasswordRequest.NewPassword)"
                      Label="Новый пароль"
                      Required="true"
                      Class="mt-3"
                      InputType="@NewPassword.Type" Adornment="Adornment.End" AdornmentIcon="@NewPassword.Icon" OnAdornmentClick="() => ShowPassword(NewPassword)" AdornmentAriaLabel="Show Password" />
        <MudTextField T="string"
                      @bind-Value="resetUserPasswordRequest.ConfirmPassword"
                      For="@(() => resetUserPasswordRequest.ConfirmPassword)"
                      Label="Подтверждение пароля"
                      Required="true"
                      Class="mt-3"
                      InputType="@ConfirmPassword.Type" Adornment="Adornment.End" AdornmentIcon="@ConfirmPassword.Icon" OnAdornmentClick="() => ShowPassword(ConfirmPassword)" AdornmentAriaLabel="Show Password" />
        <MudCheckBox @bind-Value="resetUserPasswordRequest.ResetPassword"                     
                     Color="Color.Primary"
                     Class="mt-3" >
            <MudText Typo="Typo.caption">Требовать смену пароля при первом входе</MudText>
        </MudCheckBox>
        <MudButton ButtonType="ButtonType.Submit"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   Class="mt-5">
            Сбросить пароль
        </MudButton>
    </EditForm>
</MudPaper>

@code {

    [Parameter]
    public string UserName { get; set; }

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [CascadingParameter(Name = "UserProfile")]
    private UserProfile UserProfile { get; set; }

    private class PasswordFieldState
    {
        public InputType Type { get; set; } = InputType.Password;
        public string Icon { get; set; } = Icons.Material.Filled.VisibilityOff;
    }

    private PasswordFieldState NewPassword { get; set; } = new();
    private PasswordFieldState ConfirmPassword { get; set; } = new();

    protected override async Task OnParametersSetAsync()
    {
        resetUserPasswordRequest.UserName = UserName;
        StateHasChanged();
    }

    void ShowPassword(PasswordFieldState field)
    {
        if (field.Type == InputType.Password)
        {
            field.Type = InputType.Text;
            field.Icon = Icons.Material.Filled.Visibility;
        }
        else
        {
            field.Type = InputType.Password;
            field.Icon = Icons.Material.Filled.VisibilityOff;
        }

        // Нужно обновить состояние компонента, чтобы изменения отразились
        StateHasChanged();
    }

    // Экземпляр модели, к которому привязана форма.
    private ResetUserPasswordCommand resetUserPasswordRequest { get; set; } = new() { UserProfile = new UserProfile() };

    /// <summary>
    /// Этот метод вызывается при нажатии на кнопку "Изменить".
    /// </summary>
    private async Task SubmitForm()
    {
        resetUserPasswordRequest.UserProfile =  UserProfile;
        var res = await _mediatr.Send(resetUserPasswordRequest);

        if (res.Status)
        {
            var userName = res.Data;
            _snackbar.Add($"Пароль успешно изменен: {userName} !", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        else
        {

            _snackbar.Add($"Ошибка при изменении пароля! {res.StatusMessage}", Severity.Warning);
        }
    }
}