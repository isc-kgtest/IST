
@using ActualLab.Fusion
@using IST.Contracts.Features.Auth
@using IST.Contracts.Features.Auth.Commands
@using Microsoft.AspNetCore.Components.Forms

@inject IAuthCommands _authCommands
@inject IST.Admin.Auth.SessionAccessor _session

<MudPaper Elevation="0" Style="width: 370px;">
    <EditForm Model="@_request" OnValidSubmit="SubmitForm">
        <DataAnnotationsValidator />
        <MudTextField T="string"
                      @bind-Value="_request.Login"
                      For="@(() => _request.Login)"
                      Label="Логин"
                      ReadOnly="true"
                      Required="true" />
        <MudTextField T="string"
                      @bind-Value="_request.NewPassword"
                      For="@(() => _request.NewPassword)"
                      Label="Новый пароль"
                      Required="true"
                      Class="mt-3"
                      InputType="@NewPassword.Type"
                      Adornment="Adornment.End"
                      AdornmentIcon="@NewPassword.Icon"
                      OnAdornmentClick="() => ShowPassword(NewPassword)"
                      AdornmentAriaLabel="Show Password" />
        <MudTextField T="string"
                      @bind-Value="_request.ConfirmPassword"
                      For="@(() => _request.ConfirmPassword)"
                      Label="Подтверждение пароля"
                      Required="true"
                      Class="mt-3"
                      InputType="@ConfirmPassword.Type"
                      Adornment="Adornment.End"
                      AdornmentIcon="@ConfirmPassword.Icon"
                      OnAdornmentClick="() => ShowPassword(ConfirmPassword)"
                      AdornmentAriaLabel="Show Password" />
        <MudCheckBox @bind-Value="_request.ResetPassword"
                     Color="Color.Primary"
                     Class="mt-3">
            <MudText Typo="Typo.caption">Требовать смену пароля при первом входе</MudText>
        </MudCheckBox>
        <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-5" Spacing="2">
            <MudButton OnClick="Cancel"
                       Variant="Variant.Text"
                       Color="Color.Default"
                       Disabled="_isProcessing">
                Отмена
            </MudButton>
            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="_isProcessing">
                @(_isProcessing ? "Сохранение..." : "Сбросить пароль")
            </MudButton>
        </MudStack>
        <MudProgressLinear Color="Color.Primary" Indeterminate="_isProcessing" Class="mt-4" />
    </EditForm>
</MudPaper>

@code {

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public string Login { get; set; } = "";

    private bool _isProcessing;

    private class PasswordFieldState
    {
        public InputType Type { get; set; } = InputType.Password;
        public string Icon { get; set; } = Icons.Material.Filled.VisibilityOff;
    }

    private PasswordFieldState NewPassword { get; set; } = new();
    private PasswordFieldState ConfirmPassword { get; set; } = new();

    private ResetUserPasswordRequest _request { get; set; } = new();

    protected override void OnParametersSet()
    {
        _request.Login = Login;
    }

    void ShowPassword(PasswordFieldState field)
    {
        if (field.Type == InputType.Password)
        {
            field.Type = InputType.Text;
            field.Icon = Icons.Material.Filled.Visibility;
        }
        else
        {
            field.Type = InputType.Password;
            field.Icon = Icons.Material.Filled.VisibilityOff;
        }

        StateHasChanged();
    }

    private void Cancel() => MudDialog?.Cancel();

    private async Task SubmitForm()
    {
        if (_isProcessing)
            return;

        _isProcessing = true;

        try
        {
            var command = new ResetUserPasswordCommand(await _session.GetAsync(), _request);
            var res = await _authCommands.ResetUserPasswordAsync(command);

            if (res.Status)
            {
                _snackbar.Add($"Пароль успешно сброшен: {res.Data}", Severity.Success);
                MudDialog?.Close(DialogResult.Ok(true));
            }
            else
            {
                _snackbar.Add($"Ошибка при сбросе пароля: {res.StatusMessage}", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            _snackbar.Add($"Непредвиденная ошибка: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }
}
