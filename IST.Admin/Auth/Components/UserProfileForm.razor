
@using IST.Contracts.Features.Auth.Commands
@using Microsoft.AspNetCore.Components.Forms

<MudPaper Class="" Elevation="0">
    <EditForm Model="@updateUserModel" OnValidSubmit="SubmitForm">
        <DataAnnotationsValidator />
        @* <MudText Typo="Typo.h5" GutterBottom="true">Профиль пользователя</MudText> *@
        <MudTextField T="string"
        @bind-Value="updateUserModel.Request.Name"
        For="@(() => updateUserModel.Request.Name)"
        Label="Логин"
        Required="true" />
        <MudTextField T="string"
        @bind-Value="updateUserModel.Request.Surname"
        For="@(() => updateUserModel.Request.Surname)"
        Label="Фамилия"
        Required="true"
        Class="mt-3" />
