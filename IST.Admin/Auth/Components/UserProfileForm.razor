
@using ActualLab.Fusion
@using IST.Contracts.Features.Auth
@using IST.Contracts.Features.Auth.Commands
@using Microsoft.AspNetCore.Components.Forms

@inject IAuthCommands _authCommands
@inject IAuthQueries _authQueries

<MudPaper Elevation="0" Style="min-width: 420px;">
    @if (_loading)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-8">
            <MudProgressCircular Indeterminate="true" />
            <MudText Typo="Typo.caption">Загрузка данных...</MudText>
        </MudStack>
    }
    else if (_notFound)
    {
        <MudAlert Severity="Severity.Error">Пользователь не найден.</MudAlert>
    }
    else
    {
        <EditForm Model="@_request" OnValidSubmit="SubmitForm">
            <DataAnnotationsValidator />

            <MudTextField T="string"
                          Value="@_login"
                          Label="Логин"
                          ReadOnly="true" />

            <MudTextField T="string"
                          @bind-Value="_request.Surname"
                          For="@(() => _request.Surname)"
                          Label="Фамилия"
                          Required="true"
                          Class="mt-3" />
            <MudTextField T="string"
                          @bind-Value="_request.Name"
                          For="@(() => _request.Name)"
                          Label="Имя"
                          Required="true"
                          Class="mt-3" />
            <MudTextField T="string"
                          @bind-Value="_request.Patronymic"
                          For="@(() => _request.Patronymic)"
                          Label="Отчество"
                          Class="mt-3" />
            <MudTextField T="string"
                          @bind-Value="_request.Position"
                          For="@(() => _request.Position)"
                          Label="Должность"
                          Required="true"
                          Class="mt-3" />
            <MudTextField T="string"
                          @bind-Value="_request.Department"
                          For="@(() => _request.Department)"
                          Label="Подразделение"
                          Class="mt-3" />
            <MudTextField T="string"
                          @bind-Value="_request.EMail"
                          For="@(() => _request.EMail)"
                          Label="Email"
                          InputType="InputType.Email"
                          Required="true"
                          Class="mt-3" />
            <MudTextField T="string"
                          @bind-Value="_request.PhoneNumber"
                          For="@(() => _request.PhoneNumber)"
                          Label="Телефон"
                          InputType="InputType.Telephone"
                          Required="true"
                          Class="mt-3" />

            <MudCheckBox @bind-Value="_request.IsActive"
                         Color="Color.Primary"
                         Class="mt-3">
                <MudText Typo="Typo.caption">Учётная запись активна</MudText>
            </MudCheckBox>

            <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-5" Spacing="2">
                <MudButton OnClick="Cancel"
                           Variant="Variant.Text"
                           Color="Color.Default"
                           Disabled="_isProcessing">
                    Отмена
                </MudButton>
                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Disabled="_isProcessing">
                    @(_isProcessing ? "Сохранение..." : "Сохранить")
                </MudButton>
            </MudStack>
            <MudProgressLinear Color="Color.Primary" Indeterminate="_isProcessing" Class="mt-4" />
        </EditForm>
    }
</MudPaper>

@code {

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public Guid UserId { get; set; }

    private bool _loading = true;
    private bool _notFound;
    private bool _isProcessing;
    private string _login = "";

    private UpdateUserRequest _request { get; set; } = new();

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _notFound = false;

        try
        {
            var user = await _authQueries.GetUserByIdAsync(UserId);

            if (user == null)
            {
                _notFound = true;
                _snackbar.Add("Не удалось загрузить пользователя", Severity.Error);
                return;
            }

            _login = user.Login;
            _request = new UpdateUserRequest
            {
                Id = user.Id,
                Surname = user.Surname ?? "",
                Name = user.Name ?? "",
                Patronymic = user.Patronymic,
                Position = user.Position ?? "",
                Organization = user.OrganizationId,
                Department = user.Department,
                EMail = user.EMail ?? "",
                PhoneNumber = user.PhoneNumber ?? "",
                IsActive = user.IsActive
            };
        }
        catch (Exception ex)
        {
            _snackbar.Add($"Ошибка загрузки: {ex.Message}", Severity.Error);
            _notFound = true;
        }
        finally
        {
            _loading = false;
        }
    }

    private void Cancel() => MudDialog?.Cancel();

    private async Task SubmitForm()
    {
        if (_isProcessing)
            return;

        _isProcessing = true;

        try
        {
            var command = new UpdateUserCommand(Session.Default, _request);
            var res = await _authCommands.UpdateUserAsync(command);

            if (res.Status && res.Data != null)
            {
                _snackbar.Add($"Данные пользователя сохранены: {res.Data.FullName}", Severity.Success);
                MudDialog?.Close(DialogResult.Ok(true));
            }
            else
            {
                _snackbar.Add($"Ошибка сохранения: {res.StatusMessage}", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            _snackbar.Add($"Непредвиденная ошибка: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }
}
