@using ActualLab.Fusion
@using IST.Contracts.Features.Auth
@using IST.Contracts.Features.Auth.Commands
@using Microsoft.AspNetCore.Components.Forms

@inject IAuthCommands _authCommands
@inject IST.Admin.Auth.SessionAccessor _session

<MudPaper Elevation="0" Style="min-width: 420px;">
    <EditForm Model="@_request" OnValidSubmit="SubmitForm">
        <DataAnnotationsValidator />
        <MudText Typo="Typo.h5" GutterBottom="true">Создание пользователя</MudText>

        <MudTextField T="string"
                      @bind-Value="_request.Surname"
                      For="@(() => _request.Surname)"
                      Label="Фамилия"
                      Required="true" />
        <MudTextField T="string"
                      @bind-Value="_request.Name"
                      For="@(() => _request.Name)"
                      Label="Имя"
                      Required="true"
                      Class="mt-3" />
        <MudTextField T="string"
                      @bind-Value="_request.Patronymic"
                      For="@(() => _request.Patronymic)"
                      Label="Отчество"
                      Class="mt-3" />
        <MudTextField T="string"
                      @bind-Value="_request.Position"
                      For="@(() => _request.Position)"
                      Label="Должность"
                      Required="true"
                      Class="mt-3" />
        <MudTextField T="string"
                      @bind-Value="_request.Department"
                      For="@(() => _request.Department)"
                      Label="Подразделение"
                      Required="true"
                      Class="mt-3" />
        <MudTextField T="string"
                      @bind-Value="_request.EMail"
                      For="@(() => _request.EMail)"
                      Label="Email"
                      InputType="InputType.Email"
                      Required="true"
                      Class="mt-3" />
        <MudTextField T="string"
                      @bind-Value="_request.PhoneNumber"
                      For="@(() => _request.PhoneNumber)"
                      Label="Телефон"
                      InputType="InputType.Telephone"
                      Required="true"
                      Class="mt-3" />

        <MudDivider Class="my-4" />

        <MudTextField T="string"
                      @bind-Value="_request.Login"
                      For="@(() => _request.Login)"
                      Label="Логин"
                      Required="true" />
        <MudTextField T="string"
                      @bind-Value="_request.Password"
                      For="@(() => _request.Password)"
                      Label="Пароль"
                      Required="true"
                      Class="mt-3"
                      InputType="@PasswordInput"
                      Adornment="Adornment.End"
                      AdornmentIcon="@PasswordInputIcon"
                      OnAdornmentClick="ShowPassword"
                      AdornmentAriaLabel="Show Password" />
        <MudCheckBox @bind-Value="_request.IsActive"
                     Color="Color.Primary"
                     Class="mt-3">
            <MudText Typo="Typo.caption">Учётная запись активна</MudText>
        </MudCheckBox>

        <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-5" Spacing="2">
            <MudButton OnClick="Cancel"
                       Variant="Variant.Text"
                       Color="Color.Default"
                       Disabled="_isProcessing">
                Отмена
            </MudButton>
            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="_isProcessing">
                @(_isProcessing ? "Создание..." : "Создать")
            </MudButton>
        </MudStack>
        <MudProgressLinear Color="Color.Primary" Indeterminate="_isProcessing" Class="mt-4" />
    </EditForm>
</MudPaper>

@code {

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private bool _isProcessing;
    private bool _isShow;
    private InputType PasswordInput = InputType.Password;
    private string PasswordInputIcon = Icons.Material.Filled.VisibilityOff;

    private CreateUserRequest _request { get; set; } = new() { IsActive = true };

    void ShowPassword()
    {
        if (_isShow)
        {
            _isShow = false;
            PasswordInputIcon = Icons.Material.Filled.VisibilityOff;
            PasswordInput = InputType.Password;
        }
        else
        {
            _isShow = true;
            PasswordInputIcon = Icons.Material.Filled.Visibility;
            PasswordInput = InputType.Text;
        }
    }

    private void Cancel() => MudDialog?.Cancel();

    private async Task SubmitForm()
    {
        if (_isProcessing)
            return;

        _isProcessing = true;

        try
        {
            var command = new CreateUserCommand(await _session.GetAsync(), _request);
            var res = await _authCommands.CreateUserAsync(command);

            if (res.Status && res.Data != null)
            {
                _snackbar.Add($"Пользователь успешно создан: {res.Data.Login}", Severity.Success);
                MudDialog?.Close(DialogResult.Ok(true));
            }
            else
            {
                _snackbar.Add($"Ошибка создания: {res.StatusMessage}", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            _snackbar.Add($"Непредвиденная ошибка: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }
}
