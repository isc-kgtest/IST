@using ActualLab.Fusion
@using IST.Contracts.Features.Auth
@using IST.Contracts.Features.Auth.Commands
@using Microsoft.AspNetCore.Components.Forms

@inject IAuthCommands _authCommands
@inject IST.Admin.Auth.SessionAccessor _session

<MudPaper Style="width:300px;" Elevation="0">
    <EditForm Model="@_request" OnValidSubmit="SubmitForm">
        <DataAnnotationsValidator />
        <MudTextField T="string"
                      @bind-Value="_request.Name"
                      For="@(() => _request.Name)"
                      Label="Название"
                      Required="true" />
        <MudTextField T="string"
                      @bind-Value="_request.Description"
                      For="@(() => _request.Description)"
                      Label="Описание"
                      Required="true"
                      Class="mt-3" />
        <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-5" Spacing="2">
            <MudButton OnClick="Cancel"
                       Variant="Variant.Text"
                       Color="Color.Default"
                       Disabled="_isProcessing">
                Отмена
            </MudButton>
            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="_isProcessing">
                @(_isProcessing ? "Создание..." : "Добавить")
            </MudButton>
        </MudStack>
        <MudProgressLinear Color="Color.Primary" Indeterminate="_isProcessing" Class="mt-4" />
    </EditForm>
</MudPaper>

@code {

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    private bool _isProcessing;

    private CreateRoleRequest _request { get; set; } = new();

    private void Cancel() => MudDialog?.Cancel();

    private async Task SubmitForm()
    {
        if (_isProcessing)
            return;

        _isProcessing = true;

        try
        {
            var command = new CreateRoleCommand(await _session.GetAsync(), _request);
            var res = await _authCommands.CreateRoleAsync(command);

            if (res.Status && res.Data != null)
            {
                _snackbar.Add($"Роль успешно создана: {res.Data.Name}", Severity.Success);
                MudDialog?.Close(DialogResult.Ok(true));
            }
            else
            {
                _snackbar.Add($"Ошибка создания: {res.StatusMessage}", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            _snackbar.Add($"Непредвиденная ошибка: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }
}
