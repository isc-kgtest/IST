@using IST.Contracts.Features.Auth.Commands
@using Microsoft.AspNetCore.Components.Forms

<MudPaper Style="width:250px;" Class="" Elevation="0">
    <EditForm Model="@createRoleModel" OnValidSubmit="SubmitForm">
        <DataAnnotationsValidator />
        @* <MudText Typo="Typo.h5" GutterBottom="true">Добавить новый роль</MudText> *@
        <MudTextField T="string"
                      @bind-Value="createRoleModel.Request.Name"
                      For="@(() => createRoleModel.Request.Name)"
                      Label="Название"
                      Required="true"/>
        <MudTextField T="string"
                      @bind-Value="createRoleModel.Request.Description"
                      For="@(() => createRoleModel.Request.Description)"
                      Label="Описание"
                      Required="true"
                      Class="mt-3" />
        <MudButton ButtonType="ButtonType.Submit"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   Class="mt-5">
                   Добавить
        </MudButton>
    </EditForm>
</MudPaper>

