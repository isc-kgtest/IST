@page "/"
@attribute [Authorize]
@inherits IST.Admin.Shared.Components.LangAwareComponentBase

<PageTitle>IST Admin — @Lang.L("nav_dashboard")</PageTitle>

<MudText Typo="Typo.h4" Class="mb-2"><b>@Lang.L("nav_dashboard")</b></MudText>
<MudText Typo="Typo.subtitle1" Class="mb-6" Color="Color.Secondary">
    @Lang.T("Добро пожаловать, администратор", "Кош келиңиз, администратор")
</MudText>

<MudGrid>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Elevation="3" Class="pa-4 d-flex align-center" Style="border-left: 4px solid #7c3aed; border-radius: 12px;">
            <MudIcon Icon="@Icons.Material.Filled.People" Style="font-size: 40px; color: #7c3aed;" Class="mr-4" />
            <div>
                <MudText Typo="Typo.h5"><b>—</b></MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @Lang.T("Всего пользователей", "Бардык колдонуучулар")
                </MudText>
            </div>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Elevation="3" Class="pa-4 d-flex align-center" Style="border-left: 4px solid #06b6d4; border-radius: 12px;">
            <MudIcon Icon="@Icons.Material.Filled.MenuBook" Style="font-size: 40px; color: #06b6d4;" Class="mr-4" />
            <div>
                <MudText Typo="Typo.h5"><b>—</b></MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @Lang.T("Справочников", "Справочниктер")
                </MudText>
            </div>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Elevation="3" Class="pa-4 d-flex align-center" Style="border-left: 4px solid #10b981; border-radius: 12px;">
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Style="font-size: 40px; color: #10b981;" Class="mr-4" />
            <div>
                <MudText Typo="Typo.h5"><b>@Lang.T("Активна", "Активдүү")</b></MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @Lang.T("Статус системы", "Системанын статусу")
                </MudText>
            </div>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Elevation="3" Class="pa-4 d-flex align-center" Style="border-left: 4px solid #f59e0b; border-radius: 12px;">
            <MudIcon Icon="@Icons.Material.Filled.Security" Style="font-size: 40px; color: #f59e0b;" Class="mr-4" />
            <div>
                <MudText Typo="Typo.h5"><b>—</b></MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @Lang.T("Ролей настроено", "Ролдор тууралагандай")
                </MudText>
            </div>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudGrid Class="mt-6">
    <MudItem xs="12" md="6">
        <MudPaper Elevation="2" Class="pa-6" Style="border-radius: 12px;">
            <MudText Typo="Typo.h6" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Class="mr-2" />
                @Lang.T("Быстрые действия", "Тез аракеттер")
            </MudText>
            <MudDivider Class="mb-4" />
            <MudList T="string">
                <MudListItem Icon="@Icons.Material.Filled.ManageAccounts" Href="/authadminpage">
                    @Lang.L("nav_access")
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.VpnKey" Href="/security/permissions">
                    @Lang.L("nav_permissions")
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.AccountTree" Href="/organization">
                    @Lang.L("nav_organization")
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.History" Href="/security/audit">
                    @Lang.L("nav_audit")
                </MudListItem>
            </MudList>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudPaper Elevation="2" Class="pa-6" Style="border-radius: 12px;">
            <MudText Typo="Typo.h6" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.History" Class="mr-2" />
                @Lang.T("Последняя активность", "Акыркы аракеттер")
            </MudText>
            <MudDivider Class="mb-4" />
            <MudTimeline TimelinePosition="TimelinePosition.Left">
                <MudTimelineItem Color="Color.Success" Size="Size.Small">
                    <MudText Typo="Typo.body2">@Lang.T("Успешный вход администратора", "Администратор ийгиликтүү кирди")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">2 @Lang.T("минуты назад", "мүнөт мурун")</MudText>
                </MudTimelineItem>
                <MudTimelineItem Color="Color.Info" Size="Size.Small">
                    <MudText Typo="Typo.body2">@Lang.T("Обновление справочника", "Справочник жаңыртылды")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">1 @Lang.T("час назад", "саат мурун")</MudText>
                </MudTimelineItem>
                <MudTimelineItem Color="Color.Warning" Size="Size.Small">
                    <MudText Typo="Typo.body2">@Lang.T("Изменена конфигурация системы", "Система тууралоосу өзгөргөн")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">3 @Lang.T("часа назад", "саат мурун")</MudText>
                </MudTimelineItem>
            </MudTimeline>
        </MudPaper>
    </MudItem>
</MudGrid>
