@using ActualLab.Fusion
@using IST.Contracts.Features.Auth
@using IST.Contracts.Features.Auth.Commands
@using IST.Shared.DTOs.Auth
@using IST.Shared.DTOs.Common
@using MudBlazor

@inject IAuthCommands _commands
@inject IST.Admin.Auth.SessionAccessor _session

<div class="d-flex align-center mb-4 gap-2 flex-wrap">
    <MudIcon Icon="@(IsAdminRole ? Icons.Material.Filled.AdminPanelSettings : Icons.Material.Filled.Group)"
             Color="@(IsAdminRole ? Color.Warning : Color.Primary)" />
    <MudText Typo="Typo.h6"><b>@Role.Name</b></MudText>
    @if (!string.IsNullOrEmpty(Role.Description))
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary">— @Role.Description</MudText>
    }
    <MudSpacer />
    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
             Color="@(IsAdminRole ? Color.Warning : Color.Primary)">
        @(_selected.Count) / @AllPermissions.Count привилегий
    </MudChip>
</div>

@if (IsAdminRole)
{
    <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-4">
        <b>Это системная роль admin.</b> У неё всегда все привилегии — защита, чтобы
        нельзя было случайно отрезать админу путь обратно к управлению. Чтобы создать
        ограниченную роль (например «editor»), используйте
        <MudLink Href="/authadminpage" Color="Color.Inherit"><u>Управление доступом → Роли</u></MudLink>.
    </MudAlert>
}

@if (AllPermissions.Count == 0)
{
    <MudAlert Severity="Severity.Info" Dense="true">
        Список привилегий пуст. Перезапустите Server, чтобы seeder создал записи.
    </MudAlert>
}
else
{
    @foreach (var group in AllPermissions.GroupBy(p => p.Category ?? "Прочее").OrderBy(g => g.Key))
    {
        var groupCount = group.Count();
        var groupSelected = group.Count(p => _selected.Contains(p.Id));
        <MudPaper Elevation="0" Outlined="true" Class="pa-3 mb-3">
            <div class="d-flex align-center mb-2">
                <MudText Typo="Typo.subtitle1"><b>@group.Key</b></MudText>
                <MudSpacer />
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @groupSelected / @groupCount
                </MudText>
                @if (!IsAdminRole)
                {
                    <MudButton Size="Size.Small" Class="ml-2"
                               OnClick="@(() => SelectGroup(group, true))"
                               Disabled="@(_saving || groupSelected == groupCount)">
                        Все
                    </MudButton>
                    <MudButton Size="Size.Small"
                               OnClick="@(() => SelectGroup(group, false))"
                               Disabled="@(_saving || groupSelected == 0)">
                        Снять
                    </MudButton>
                }
            </div>
            <div class="d-flex flex-column gap-1">
                @foreach (var p in group.OrderBy(p => p.Code))
                {
                    <MudCheckBox T="bool"
                                 Value="@_selected.Contains(p.Id)"
                                 ValueChanged="@(checkedNow => Toggle(p.Id, checkedNow))"
                                 Disabled="@(IsAdminRole || _saving)"
                                 Color="Color.Primary">
                        <ChildContent>
                            <span><code>@p.Code</code>
                                @if (!string.IsNullOrEmpty(p.Description))
                                {
                                    <span style="opacity:0.7;"> — @p.Description</span>
                                }
                            </span>
                        </ChildContent>
                    </MudCheckBox>
                }
            </div>
        </MudPaper>
    }

    @if (!IsAdminRole)
    {
        <div class="d-flex justify-end mt-4 gap-2">
            <MudButton Variant="Variant.Outlined" OnClick="ResetChanges" Disabled="@(_saving || !Dirty)">
                Отменить изменения
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="@(_saving || !Dirty)">
                @(_saving ? "Сохраняем..." : "Сохранить")
            </MudButton>
        </div>
    }
}

@code {
    [Parameter] public RoleDto Role { get; set; } = null!;
    [Parameter] public List<PermissionDto> AllPermissions { get; set; } = new();
    [Parameter] public List<Guid> AssignedIds { get; set; } = new();
    [Parameter] public EventCallback OnSaved { get; set; }

    private HashSet<Guid> _initial = new();
    private HashSet<Guid> _selected = new();
    private bool _saving;
    private bool Dirty => !_initial.SetEquals(_selected);
    private bool IsAdminRole => string.Equals(Role.Name, "admin", StringComparison.OrdinalIgnoreCase);

    protected override void OnParametersSet()
    {
        _initial = AssignedIds.ToHashSet();
        _selected = new HashSet<Guid>(_initial);
    }

    private void Toggle(Guid id, bool isChecked)
    {
        if (IsAdminRole) return;
        if (isChecked) _selected.Add(id);
        else _selected.Remove(id);
        StateHasChanged();
    }

    private void SelectGroup(IGrouping<string, PermissionDto> group, bool select)
    {
        if (IsAdminRole) return;
        foreach (var p in group)
        {
            if (select) _selected.Add(p.Id);
            else _selected.Remove(p.Id);
        }
        StateHasChanged();
    }

    private void ResetChanges()
    {
        _selected = new HashSet<Guid>(_initial);
        StateHasChanged();
    }

    private async Task SaveAsync()
    {
        if (_saving || IsAdminRole) return;
        _saving = true;
        try
        {
            var session = await _session.GetAsync();
            var cmd = new UpdateRolePermissionsCommand(session, Role.Id, _selected.ToArray());
            var res = await _commands.UpdateRolePermissionsAsync(cmd);
            if (res.Status)
            {
                _snackbar.Add(res.StatusMessage ?? "Сохранено.", Severity.Success);
                _initial = new HashSet<Guid>(_selected);
                await OnSaved.InvokeAsync();
            }
            else
            {
                _snackbar.Add(res.StatusMessage ?? "Ошибка сохранения.", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            _snackbar.Add($"Ошибка: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }
}
