@page "/dictionaries"
@using IST.Admin.Features.Dictionaries.Components
@using IST.Shared.DTOs.Dictionaries

@attribute [Authorize(Roles = "admin")]

@inherits ActualLab.Fusion.Blazor.ComputedStateComponent<IST.Admin.Features.Dictionaries.Pages.DictionariesPage.Model>

<PageTitle>Конструктор справочников</PageTitle>

<MudAlert Elevation="0" Dense="true" Class="mb-4" Severity="Severity.Info">
	Конструктор справочников — создание и управление динамическими справочниками
</MudAlert>

@if (_selectedDictionary == null)
{
	@* ═══════════ СПИСОК СПРАВОЧНИКОВ ═══════════ *@
	<MudDataGrid T="DictionaryDto"
				 Items="@(State.ValueOrDefault?.Dictionaries ?? new())"
				 Hover="true" Striped="true" Dense="true"
				 Filterable="true" SortMode="SortMode.Multiple"
				 QuickFilter="@_filter"
				 Loading="@_processing">
		<ToolBarContent>
			<MudText Typo="Typo.h6">Справочники</MudText>
			<MudSpacer />
			<MudTextField @bind-Value="_searchString"
						  Placeholder="Поиск по названию..."
						  Adornment="Adornment.Start"
						  AdornmentIcon="@Icons.Material.Filled.Search"
						  IconSize="Size.Medium"
						  Class="mt-0 mr-4" Clearable="true" />
			<MudTooltip Placement="Placement.Top" Text="Создать справочник">
				<MudFab Size="Size.Small" Color="Color.Success" StartIcon="@Icons.Material.Rounded.Add" OnClick="ShowCreateDictionaryDialog" />
			</MudTooltip>
			<MudTooltip Placement="Placement.Top" Text="Обновить">
				<MudFab Size="Size.Small" Class="ml-2" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Refresh" OnClick="RefreshAsync" />
			</MudTooltip>
		</ToolBarContent>
		<Columns>
			<PropertyColumn Property="x => x.Name" Title="Наименование" />
			<PropertyColumn Property="x => x.Slug" Title="Slug" />
			<PropertyColumn Property="x => x.Description" Title="Описание" />
			<PropertyColumn Property="x => x.FieldCount" Title="Полей" />
			<PropertyColumn Property="x => x.CreatedAt" Title="Создан" Format="dd.MM.yyyy" />
			<TemplateColumn Title="Действия" Filterable="false" Sortable="false">
				<CellTemplate>
					<MudMenu Icon="@Icons.Material.Filled.MoreVert" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Dense="true" Size="Size.Small">
						<MudMenuItem Icon="@Icons.Material.Rounded.OpenInNew" OnClick="() => OpenDictionary(context.Item)">Открыть</MudMenuItem>
						<MudMenuItem Icon="@Icons.Material.Rounded.Edit" OnClick="() => ShowEditDictionaryDialog(context.Item)">Редактировать</MudMenuItem>
						<MudDivider />
						<MudMenuItem Icon="@Icons.Material.Rounded.Delete" IconColor="Color.Error" OnClick="() => ShowDeleteDictionaryDialog(context.Item.Id, context.Item.Name)">Удалить</MudMenuItem>
					</MudMenu>
				</CellTemplate>
			</TemplateColumn>
		</Columns>
		<PagerContent>
			<MudDataGridPager T="DictionaryDto" PageSizeOptions="new int[] { 10, 25, 50 }" />
		</PagerContent>
	</MudDataGrid>
}
else
{
	@* ═══════════ ДЕТАЛЬНЫЙ ПРОСМОТР СПРАВОЧНИКА ═══════════ *@
	<MudButton StartIcon="@Icons.Material.Rounded.ArrowBack"
			   Variant="Variant.Text" Color="Color.Default" Class="mb-3"
			   OnClick="CloseDictionary">
		Назад к списку
	</MudButton>

	<MudText Typo="Typo.h5" Class="mb-2">@_selectedDictionary.Name</MudText>
	@if (!string.IsNullOrEmpty(_selectedDictionary.Description))
	{
		<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">@_selectedDictionary.Description</MudText>
	}

	<MudTabs Outlined="true" Rounded="true" ApplyEffectsToContainer="true">
		@* ── Структура полей ── *@
		<MudTabPanel Text="Структура полей" Icon="@Icons.Material.Rounded.TableChart">
			<MudDataGrid T="DictionaryFieldDto"
						 Items="@(State.ValueOrDefault?.Detail?.Fields ?? new())"
						 Hover="true" Striped="true" Dense="true"
						 Loading="_processing">
				<ToolBarContent>
					<MudText Typo="Typo.h6">Поля справочника</MudText>
					<MudSpacer />
					<MudTooltip Placement="Placement.Top" Text="Добавить поле">
						<MudFab Size="Size.Small" Color="Color.Success" StartIcon="@Icons.Material.Rounded.Add" OnClick="ShowAddFieldDialog" />
					</MudTooltip>
				</ToolBarContent>
				<Columns>
					<PropertyColumn Property="x => x.SortOrder" Title="#" />
					<PropertyColumn Property="x => x.FieldKey" Title="Ключ" />
					<PropertyColumn Property="x => x.DisplayName" Title="Отображение" />
					<PropertyColumn Property="x => x.FieldType" Title="Тип" />
					<TemplateColumn Title="Обяз." SortBy="x => x.IsRequired">
						<CellTemplate>
							<MudChip T="string" Color="@(context.Item.IsRequired ? Color.Warning : Color.Default)" Size="Size.Small" Variant="Variant.Outlined">
								@(context.Item.IsRequired ? "Да" : "Нет")
							</MudChip>
						</CellTemplate>
					</TemplateColumn>
					<TemplateColumn Title="Действия" Filterable="false" Sortable="false">
						<CellTemplate>
							<MudIconButton Icon="@Icons.Material.Rounded.Edit" Size="Size.Small" OnClick="() => ShowEditFieldDialog(context.Item)" />
							<MudIconButton Icon="@Icons.Material.Rounded.Delete" Size="Size.Small" Color="Color.Error" OnClick="() => ShowDeleteFieldDialog(context.Item.Id, context.Item.DisplayName)" />
						</CellTemplate>
					</TemplateColumn>
				</Columns>
			</MudDataGrid>
		</MudTabPanel>

		@* ── Записи ── *@
		<MudTabPanel Text="Записи" Icon="@Icons.Material.Rounded.Storage">
			<DictionaryRecordsGrid DictionaryId="@_selectedDictionary.Id"
								   Fields="@(State.ValueOrDefault?.Detail?.Fields ?? new())"
								   Records="@(State.ValueOrDefault?.Detail?.Records ?? new())"
								   Loading="_processing"
								   OnRefresh="RefreshAsync" />
		</MudTabPanel>
	</MudTabs>
}
