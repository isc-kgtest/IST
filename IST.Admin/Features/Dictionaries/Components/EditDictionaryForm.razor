@using ActualLab.Fusion
@using IST.Contracts.Features.Dictionaries
@using IST.Contracts.Features.Dictionaries.Commands
@using IST.Shared.DTOs.Dictionaries

@inject IDictionaryCommands _dictCommands
@inject ISnackbar _snackbar

<MudPaper Style="min-width:400px;" Elevation="0">
    <EditForm Model="@_request" OnValidSubmit="SubmitForm">
        <DataAnnotationsValidator />
        <MudTextField T="string" @bind-Value="_request.Name" Label="Наименование" Required="true" />
        <MudTextField T="string" @bind-Value="_request.Slug" Label="Slug" Required="true" Class="mt-3" />
        <MudTextField T="string" @bind-Value="_request.Description" Label="Описание" Lines="2" Class="mt-3" />
        <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-5" Spacing="2">
            <MudButton OnClick="Cancel" Variant="Variant.Text" Color="Color.Default" Disabled="_p">Отмена</MudButton>
            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Disabled="_p">
                @(_p ? "Сохранение..." : "Сохранить")
            </MudButton>
        </MudStack>
        <MudProgressLinear Color="Color.Primary" Indeterminate="_p" Class="mt-4" />
    </EditForm>
</MudPaper>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public DictionaryDto? Dictionary { get; set; }

    private bool _p;
    private UpdateDictionaryRequest _request = new();

    protected override void OnParametersSet()
    {
        if (Dictionary != null)
            _request = new() { Id = Dictionary.Id, Name = Dictionary.Name, Slug = Dictionary.Slug, Description = Dictionary.Description };
    }

    private void Cancel() => MudDialog?.Cancel();

    private async Task SubmitForm()
    {
        if (_p) return;
        _p = true;
        try
        {
            var res = await _dictCommands.UpdateDictionaryAsync(new UpdateDictionaryCommand(Session.Default, _request));
            if (res.Status && res.Data != null)
            {
                _snackbar.Add($"Справочник обновлён: {res.Data.Name}", Severity.Success);
                MudDialog?.Close(DialogResult.Ok(true));
            }
            else _snackbar.Add($"Ошибка: {res.StatusMessage}", Severity.Warning);
        }
        catch (Exception ex) { _snackbar.Add($"Ошибка: {ex.Message}", Severity.Error); }
        finally { _p = false; StateHasChanged(); }
    }
}
